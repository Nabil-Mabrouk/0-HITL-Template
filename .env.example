PROJECT_NAME=0hitl
ENVIRONMENT=production
VITE_API_URL=https://api.0-hitl.com

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=0hitl

# Application
# JWT
SECRET_KEY=           # openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton@gmail.com
SMTP_PASSWORD=        # App password Gmail (pas le mot de passe du compte)
EMAIL_FROM=ton@gmail.com
EMAIL_FROM_NAME=0-HITL

# Canaux d'authentification actifs
AUTH_CHANNEL_WAITLIST=true
AUTH_CHANNEL_DIRECT=false
AUTH_CHANNEL_ONBOARDING=false

# Configuration onboarding
AUTH_ONBOARDING_FLOW=0hitl        # nom du fichier de config JSON
AUTH_ONBOARDING_TARGET_ROLE=premium

GEOIP_DB_PATH=./geoip/GeoLite2-City.mmdb #download this file from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data?lang=en and place it in the geoip folder

# ── Monetization ─────────────────────────────────────────────────────────────
# Activate features independently (false by default)
MONETIZATION_SHOP=false          # One-time digital product sales
MONETIZATION_SUBSCRIPTION=false  # Stripe subscription → premium role
MONETIZATION_TRIAL_DAYS=0        # Free trial days for new subscribers (0 = no trial)

# Stripe keys — required when any monetization flag is true
STRIPE_SECRET_KEY=sk_test_…      # sk_live_… in production
STRIPE_PUBLIC_KEY=pk_test_…      # pk_live_… in production
STRIPE_WEBHOOK_SECRET=whsec_…    # from Stripe dashboard → Webhooks

# Download links (shop only)
DOWNLOAD_LINK_EXPIRE_HOURS=48    # Hours before download link expires
DOWNLOAD_MAX_ATTEMPTS=5          # Max downloads per purchase

ADMIN_EMAIL=nabil.mabrouk.ai@gmail.com
ADMIN_PASSWORD=Password123?
ADMIN_FULL_NAME=Admin